<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bulk Add Products</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 20px;
        }

        h1 {
            color: #333;
        }

        .addsection {
            background-color: white;
            border-radius: 5px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            padding: 20px;
            margin-top: 20px;
        }

        a {
            display: inline-block;
            margin: 10px 0;
            color: #007BFF;
            text-decoration: none;
        }
    </style>
</head>

<body>
    <header>
        <div class="navbar">
            <nav>
                <h3>Bulk Add Products</h3>
                <ul>
                    <li><a href="/customer-dashboard">Home</a></li>
                    <li><a href="/logout">Logout</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="addsection">
        <form action="/bulk-add" method="POST">
            <label for="jsonFile">Upload JSON:</label>
            <input type="file" id="jsonFile" name="jsonFile" accept=".json" required>
            <button type="submit">Upload</button>
        </form>
    </div>

</body>

</html>