<!DOCTYPE html>
<html>
<head>
    <title>Signup</title>
    <style>
        body {
            font-family: Arial;
            background: #f2f2f2;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .container {
            background: white;
            padding: 30px;
            border-radius: 10px;
            width: 300px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        h2 {
            text-align: center;
        }

        input {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
        }

        button {
            width: 100%;
            padding: 10px;
            background: green;
            color: white;
            border: none;
            cursor: pointer;
        }

        button:hover {
            background: darkgreen;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Signup</h2>

    <form action="/signup" method="POST">
        <input type="text" name="username" placeholder="Enter username" maxlength="15" minlength="2" required>
        <input type="email" name="email" placeholder="Enter email" maxlength="20" required>
        <input type="password" name="password" placeholder="Enter password" maxlength="14" minlength="6" required>
        <button type="submit">Signup</button>
    </form>
</div>

</body>
</html>