<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cart</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 20px;
        }

        h1 {
            color: #333;
        }

        a {
            display: inline-block;
            margin: 10px 0;
            color: #007BFF;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        .product-card {
            background-color: white;
            border-radius: 5px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            padding: 20px;
            margin-top: 20px;

        }

        .product-card ul {
            list-style-type: none;
            padding: 0;
            display: flex;
            flex-direction: row;

        }

        .product-card li {
            margin: 0 20px 0 0;
        }

    </style>

</head>
<body>
    <h1>Shopping Cart</h1>
    <p>Hello {{name}}! Your cart is currently empty.</p>
    <a href="/customer-dashboard">Back to Dashboard</a><br>
    <a href="/logout">Logout</a>

    <div class="product-card">
        <ul>
            {{#each products}}
            <li>
                <h3>{{product.productName}}</h3>
                <p>{{product.productDescription}}</p>
                <p>Price: ₹{{product.price}}</p>
                
            </li>
            {{/each}}
        </ul>
    </div>

</body>
</html>